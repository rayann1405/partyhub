# ============================================================
# PartyHub — Variables d'environnement
# Copier ce fichier en .env pour le développement local
# ============================================================

# ---- Serveur ----
PORT=3000
NODE_ENV=development

# ---- Base de données ----
# Local (Docker Compose) :
DATABASE_URL=postgresql://partyhub:partyhub@localhost:5432/partyhub

# Production → Neon (gratuit, sans limite de durée) :
#   1. Créer un compte sur https://neon.tech
#   2. Nouveau projet → copier la "Connection string"
#   3. Remplacer la valeur ci-dessus par :
#      DATABASE_URL=postgres://user:pass@ep-xxx-xxx.region.aws.neon.tech/partyhub?sslmode=require

# ---- JWT ----
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-min-32-chars-random-string-here
JWT_REFRESH_SECRET=another-random-32-chars-string-here

# ---- CORS ----
# En production : URL publique du service Render (ex: https://partyhub.onrender.com)
# Plusieurs URLs séparées par des virgules si nécessaire.
CLIENT_URL=http://localhost:5173

# ---- Cloudinary (upload images, optionnel) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# Variables frontend — développement local uniquement
# En production, le frontend est intégré dans le serveur Express.
# VITE_API_URL n'est PAS nécessaire en production.
# ============================================================
VITE_API_URL=http://localhost:3000
